[gd_scene load_steps=2 format=3 uid="uid://win_screen"]

[ext_resource type="Script" path="res://scripts/WinScreen.gd" id="1"]

[node name="WinScreen" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.05, 0.1, 0.05, 1)

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
offset_left = -150.0
offset_top = -200.0
offset_right = 150.0
offset_bottom = 200.0
theme_override_constants/separation = 30

[node name="Title" type="Label" parent="VBox"]
modulate = Color(0, 0, 0, 1)
layout_mode = 2
theme_override_font_sizes/font_size = 48
theme_override_colors/font_color = Color(0.3, 1, 0.3, 1)
text = "YOU WIN!"
horizontal_alignment = 1

[node name="Subtitle" type="Label" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
theme_override_colors/font_color = Color(0.9, 0.9, 0.9, 1)
text = "You actually survived."
horizontal_alignment = 1

[node name="DeathCount" type="Label" parent="VBox"]
layout_mode = 2
theme_override_font_sizes/font_size = 24
theme_override_colors/font_color = Color(1, 0.5, 0.5, 1)
text = "Deaths: 0"
horizontal_alignment = 1

[node name="ReplayButton" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(300, 60)
theme_override_font_sizes/font_size = 22
text = "PLAY AGAIN"

[node name="MenuButton" type="Button" parent="VBox"]
layout_mode = 2
custom_minimum_size = Vector2(300, 60)
theme_override_font_sizes/font_size = 22
text = "MAIN MENU"

[connection signal="pressed" from="VBox/ReplayButton" to="." method="_on_replay_pressed"]
[connection signal="pressed" from="VBox/MenuButton" to="." method="_on_menu_pressed"]
